{
  "name": "@openzeppelin-compact/compact",
  "private": true,
  "description": "CLI for building and packaging Compact smart contracts",
  "version": "0.0.1",
  "keywords": [
    "compact",
    "compiler",
    "packaging",
    "distribution",
    "release"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "exports": "./index.js",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "compact-builder": "dist/runBuilder.js",
    "compact-compiler": "dist/runCompiler.js"
  },
  "scripts": {
