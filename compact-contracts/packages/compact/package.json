    "types": "tsc -p tsconfig.json --noEmit",
    "test": "yarn vitest run",
    "clean": "git clean -fXd"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "log-symbols": "^7.0.0",
    "ora": "^9.3.0"
  }
}
