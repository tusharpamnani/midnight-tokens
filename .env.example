# Midnight Network Configuration
# Set to 'local' for localnet or 'preprod' for preprod network
MIDNIGHT_NETWORK=local

# Localnet endpoints (used when MIDNIGHT_NETWORK=local)
MIDNIGHT_INDEXER_HTTP=http://127.0.0.1:8088/api/v4/graphql
MIDNIGHT_INDEXER_WS=ws://127.0.0.1:8088/api/v4/graphql/ws
MIDNIGHT_NODE_HTTP=http://127.0.0.1:9944
MIDNIGHT_NODE_WS=ws://127.0.0.1:9944
MIDNIGHT_PROOF_SERVER=http://127.0.0.1:6300

# Preprod endpoints (used when MIDNIGHT_NETWORK=preprod)
# MIDNIGHT_INDEXER_HTTP=https://indexer.preprod.midnight.network/api/v3/graphql
# MIDNIGHT_INDEXER_WS=wss://indexer.preprod.midnight.network/api/v3/graphql/ws
# MIDNIGHT_NODE_HTTP=https://rpc.preprod.midnight.network
# MIDNIGHT_NODE_WS=wss://rpc.preprod.midnight.network
# MIDNIGHT_PROOF_SERVER=http://127.0.0.1:6300

# Required: Strong password for encrypted private state storage
PRIVATE_STATE_PASSWORD=Str0ng!MidnightLocal2026

# Optional: Override default deploy seed
# DEPLOY_SEED=your_hex_seed_here
